<div class="form-shell">
  <a class="back-link" href="/questions/<%= question._id %>">&larr; Back to question</a>
  <h1 class="mt-3">Edit Question</h1>
  <p class="text-secondary">Update the question content and correct answer.</p>
  <% if (error) { %>
    <div class="alert alert-danger" role="alert"><%= error %></div>
  <% } %>
  <form
    method="post"
    action="/questions/<%= question._id %>?_method=PUT"
    class="card border-0 shadow-sm p-4"
  >
    <div class="mb-3">
      <label class="form-label" for="text">Question text</label>
      <textarea class="form-control" id="text" name="text" rows="3" required><%= form.text || '' %></textarea>
    </div>
    <div class="mb-3">
      <label class="form-label" for="options">Options</label>
      <input
        class="form-control"
        id="options"
        name="options"
        value="<%= form.options || '' %>"
        placeholder="Paris, London, Berlin, Madrid"
        required
      >
      <div class="form-text">Separate options with commas or new lines. At least two are required.</div>
    </div>
    <div class="row">
      <div class="col-md-8 mb-3">
        <label class="form-label" for="keywords">Keywords</label>
        <input
          class="form-control"
          id="keywords"
          name="keywords"
          value="<%= form.keywords || '' %>"
          placeholder="capital, geography"
        >
      </div>
      <div class="col-md-4 mb-3">
        <label class="form-label" for="correctAnswerIndex">Correct answer index</label>
        <input
          class="form-control"
          id="correctAnswerIndex"
          name="correctAnswerIndex"
          type="number"
          min="0"
          value="<%= form.correctAnswerIndex ?? 0 %>"
          required
        >
        <div class="form-text">The first option has index 0.</div>
      </div>
    </div>
    <div class="d-flex gap-2 mt-2">
      <button class="btn btn-primary" type="submit">Update Question</button>
      <a class="btn btn-light" href="/questions/<%= question._id %>">Cancel</a>
    </div>
  </form>
</div>
