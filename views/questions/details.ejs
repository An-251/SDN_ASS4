<a class="back-link" href="/questions">← Back to questions</a>
<div class="detail-card card border-0 shadow-sm mt-3">
  <div class="card-body p-4 p-md-5">
    <div class="d-flex flex-column flex-md-row justify-content-between gap-3">
      <div>
        <p class="eyebrow">Question details</p>
        <h1 class="h2"><%= question.text %></h1>
      </div>
      <a class="btn btn-outline-primary align-self-start" href="/questions/<%= question._id %>/edit">Edit Question</a>
    </div>

    <h2 class="h5 mt-4">Answer options</h2>
    <ol class="list-group list-group-numbered">
      <% question.options.forEach((option, index) => { %>
        <li class="list-group-item d-flex align-items-center">
          <span class="answer-option ms-auto text-end"><%= option %></span>
          <span class="correct-indicator">
            <% if (index === question.correctAnswerIndex) { %>
              <span class="badge text-bg-success">Correct</span>
            <% } %>
          </span>
        </li>
      <% }); %>
    </ol>

    <% if (question.keywords.length) { %>
      <div class="mt-4">
        <h2 class="h5">Keywords</h2>
        <div class="d-flex flex-wrap gap-2">
          <% question.keywords.forEach((keyword) => { %>
            <span class="badge rounded-pill text-bg-light border"><%= keyword %></span>
          <% }); %>
        </div>
      </div>
    <% } %>
  </div>
</div>
