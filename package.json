{
  "name": "question-bank-management",
  "version": "2.0.0",
  "description": "Question bank management application using Express, EJS, Handlebars and MongoDB",
  "main": "server.js",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "build": "npm run build:client",
    "client": "vite --config client/vite.config.js",
    "build:client": "vite build --config client/vite.config.js",
    "seed:assignment4": "node scripts/seedAssignment4.js",
    "check": "node scripts/check.js",
    "test": "node tests/smoke.js"
  },
  "keywords": [
    "express",
    "mongoose",
    "mongodb",
    "rest-api",
    "ejs",
    "handlebars"
  ],
  "license": "ISC",
  "dependencies": {
    "@reduxjs/toolkit": "^2.12.0",
    "@vitejs/plugin-react": "^6.0.3",
    "axios": "^1.17.0",
    "bcryptjs": "^3.0.3",
    "body-parser": "^2.2.2",
    "bootstrap": "^5.3.8",
    "dotenv": "^16.4.7",
    "ejs": "^6.0.1",
    "express": "^4.21.2",
    "express-handlebars": "^8.0.3",
    "handlebars": "^4.7.9",
    "method-override": "^3.0.0",
    "mongoose": "^8.9.5",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-redux": "^9.3.0",
    "react-router-dom": "^7.18.0",
    "vite": "^8.1.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.9"
  }
}
